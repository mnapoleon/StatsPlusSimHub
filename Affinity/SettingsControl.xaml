<UserControl x:Class="Affinity.SettingsControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Affinity" />

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <CheckBox VerticalAlignment="Center"
                          Content="Enable plugin"
                          IsChecked="{Binding Settings.EnablePlugin, Mode=TwoWay}" />
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Text="Units:" />
                <CheckBox Margin="6,0,0,0"
                          VerticalAlignment="Center"
                          Content="Display miles"
                          Checked="DistanceUnitChanged"
                          Unchecked="DistanceUnitChanged"
                          IsChecked="{Binding Settings.DisplayInMiles, Mode=TwoWay}" />
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Text="Current total:" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding CurrentContextDistanceDisplay, StringFormat=F2}" />
                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding DistanceUnitLabel}" />
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Text="Session:" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding SessionDistanceDisplay, StringFormat=F2}" />
                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding DistanceUnitLabel}" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock HorizontalAlignment="Right"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="Total distance across all games:" />
                <StackPanel Margin="0,4,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{Binding TotalDistanceDisplay, StringFormat=F2}" />
                    <TextBlock Margin="4,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{Binding DistanceUnitLabel}" />
                </StackPanel>
                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding GameTabs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,0"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="12"
                                           Text="{Binding GameName}" />
                                <TextBlock Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding TotalDistanceDisplay, StringFormat=F2}" />
                                <TextBlock Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Text="{Binding DataContext.DistanceUnitLabel, ElementName=Root}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <styles:SHTabControl Grid.Row="2"
                             ItemsSource="{Binding GameTabs}"
                             SelectedItem="{Binding SelectedGameTab, Mode=TwoWay}"
                             DisplayMemberPath="GameName">
            <styles:SHTabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Tracks" />
                        <TextBlock Grid.Column="2" FontSize="14" FontWeight="SemiBold" Text="Cars" />

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TrackSummaries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*" Binding="{Binding TrackDisplayName}" Header="Track" />
                                <DataGridTextColumn Width="120" Binding="{Binding DistanceDisplay, StringFormat=F2}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{Binding DataContext.DistanceColumnHeader, ElementName=Root}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Row="1"
                                  Grid.Column="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding CarSummaries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*" Binding="{Binding CarModel}" Header="Car" />
                                <DataGridTextColumn Width="120" Binding="{Binding DistanceDisplay, StringFormat=F2}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{Binding DataContext.DistanceColumnHeader, ElementName=Root}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DataTemplate>
            </styles:SHTabControl.ContentTemplate>
        </styles:SHTabControl>

        <StackPanel Grid.Row="3"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right">
            <TextBlock TextAlignment="Right"
                       Foreground="{Binding StatusSectionForeground}"
                       Text="{Binding DataStatus}" />
            <TextBlock Margin="0,4,0,0"
                       TextAlignment="Right"
                       Foreground="{Binding StatusSectionForeground}"
                       Text="{Binding CurrentContext}" />
            <TextBlock Margin="0,4,0,0"
                       TextAlignment="Right"
                       Foreground="{Binding StatusSectionForeground}"
                       Text="{Binding DatabasePath}" />
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,12,0,0" Orientation="Horizontal">
            <Button Width="90" Click="SaveButton_Click" Content="Save" />
            <Button Width="90" Margin="8,0,0,0" Click="RefreshButton_Click" Content="Refresh" />
            <Button Width="110" Margin="8,0,0,0" Click="ResetButton_Click" Content="Reset Settings" />
            <Button Width="90" Margin="8,0,0,0" Click="ClearAllButton_Click" Content="Clear All" />
        </StackPanel>
    </Grid>
</UserControl>
