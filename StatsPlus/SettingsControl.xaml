<UserControl x:Class="StatsPlus.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:StatsPlus"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:TimeSpanSecondsFormatter x:Key="TimeSpanSecondsFormatter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <styles:SHTabControl>
            <styles:SHTabItem Header="Settings">
                <StackPanel>
                    <styles:SHSection Title="General">
                        <StackPanel Margin="12">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Margin="0,0,12,8"
                                           VerticalAlignment="Center"
                                           Text="Enable plugin" />
                                <CheckBox Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="0,0,0,8"
                                          HorizontalAlignment="Left"
                                          IsChecked="{Binding Settings.EnablePlugin, Mode=TwoWay}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,12,8"
                                           VerticalAlignment="Center"
                                           Text="Publish game / track / car" />
                                <CheckBox Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="0,0,0,8"
                                          HorizontalAlignment="Left"
                                          IsChecked="{Binding Settings.PublishTrackInfo, Mode=TwoWay}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"
                                           Text="Custom label" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Width="220"
                                         HorizontalAlignment="Left"
                                         Text="{Binding Settings.CustomLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <StackPanel Orientation="Horizontal">
                                <Button Width="120"
                                        Margin="0,0,10,0"
                                        Click="SaveButton_Click"
                                        Content="Save settings" />
                                <Button Width="140"
                                        Click="ResetButton_Click"
                                        Content="Reset defaults" />
                            </StackPanel>
                        </StackPanel>
                    </styles:SHSection>

                    <styles:SHSection Title="Enabled Games">
                        <StackPanel Margin="12">
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                StatsPlus only records laps for the enabled games below. Unsupported or disabled games are ignored.
                            </TextBlock>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Assetto Corsa" />
                                <CheckBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" HorizontalAlignment="Left" IsChecked="{Binding Settings.RecordAssettoCorsa, Mode=TwoWay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Assetto Corsa EVO" />
                                <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" HorizontalAlignment="Left" IsChecked="{Binding Settings.RecordAssettoCorsaEvo, Mode=TwoWay}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Automobilista 2" />
                                <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" HorizontalAlignment="Left" IsChecked="{Binding Settings.RecordAutomobilista2, Mode=TwoWay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="iRacing" />
                                <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" HorizontalAlignment="Left" IsChecked="{Binding Settings.RecordIRacing, Mode=TwoWay}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="rFactor 2" />
                                <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" HorizontalAlignment="Left" IsChecked="{Binding Settings.RecordRFactor2, Mode=TwoWay}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" Text="RaceRoom / RRRE" />
                                <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Left" IsChecked="{Binding Settings.RecordR3E, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </styles:SHSection>

                    <styles:SHSection Title="About">
                        <StackPanel Margin="12">
                            <TextBlock FontWeight="Bold" Text="StatsPlus" />
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                                Records lap and sector times for the active game using simple JSON persistence.
                            </TextBlock>
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                                Published properties: StatsPlus.Version, StatsPlus.Enabled, StatsPlus.Label, StatsPlus.GameName,
                                StatsPlus.TrackName, StatsPlus.CarModel, StatsPlus.SpeedKmh, StatsPlus.IsGameRunning,
                                StatsPlus.LastLapTime, StatsPlus.SessionBestLapTime, StatsPlus.AllTimeBestLapTime,
                                StatsPlus.SessionLapCount, StatsPlus.LastSector1Time, StatsPlus.LastSector2Time, StatsPlus.LastSector3Time
                            </TextBlock>
                        </StackPanel>
                    </styles:SHSection>
                </StackPanel>
            </styles:SHTabItem>

            <styles:SHTabItem Header="Laps">
                <StackPanel>
                    <styles:SHSection Title="Recorder">
                        <StackPanel Margin="12">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Status" FontWeight="Bold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding DataStatus}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" Text="Current context" FontWeight="Bold" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding CurrentContext}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" Text="Data file" FontWeight="Bold" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding DatabasePath}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" Text="Session laps" FontWeight="Bold" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SessionLapCount}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,8" Text="Last lap (s)" FontWeight="Bold" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Text="{Binding LastLapSeconds, Converter={StaticResource TimeSpanSecondsFormatter}}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,8" Text="Session best (s)" FontWeight="Bold" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SessionBestLapSeconds, Converter={StaticResource TimeSpanSecondsFormatter}}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,12,0" Text="All-time best (s)" FontWeight="Bold" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,0,0,0" Text="{Binding AllTimeBestLapSeconds, Converter={StaticResource TimeSpanSecondsFormatter}}" />
                            </Grid>

                            <Button Width="140"
                                    HorizontalAlignment="Left"
                                    Click="RefreshHistoryButton_Click"
                                    Content="Refresh history" />
                        </StackPanel>
                    </styles:SHSection>

                    <styles:SHSection Title="Stored History">
                        <StackPanel Margin="12">
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                Recorded laps are partitioned in JSON by game, then car, then track variation from TrackNameWithConfig.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Width="150"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Left"
                                        IsEnabled="{Binding HasSelectedGameHistoryTab}"
                                        Click="ClearSelectedGameButton_Click"
                                        Content="Clear selected game" />
                                <Button Width="120"
                                        HorizontalAlignment="Left"
                                        Click="ClearAllDataButton_Click"
                                        Content="Clear all data" />
                            </StackPanel>
                            <styles:SHTabControl ItemsSource="{Binding GameHistoryTabs}"
                                                 SelectedItem="{Binding SelectedGameHistoryTab, Mode=TwoWay}"
                                                 DisplayMemberPath="GameName"
                                                 Height="300">
                                <styles:SHTabControl.ContentTemplate>
                                    <DataTemplate>
                                        <DataGrid ItemsSource="{Binding Tracks}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  SelectedItem="{Binding DataContext.SelectedTrackSummary, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Car" Binding="{Binding CarModel}" Width="180" />
                                                <DataGridTextColumn Header="Track" Binding="{Binding TrackName}" Width="120" />
                                                <DataGridTextColumn Header="Variation" Binding="{Binding TrackNameWithConfigDisplay}" Width="180" />
                                                <DataGridTextColumn Header="Laps" Binding="{Binding LapCount}" Width="60" />
                                                <DataGridTextColumn Header="Best" Binding="{Binding BestLapSeconds, Converter={StaticResource TimeSpanSecondsFormatter}}" Width="90" />
                                                <DataGridTextColumn Header="Last UTC" Binding="{Binding LastRecordedUtc, StringFormat={}{0:u}}" Width="150" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DataTemplate>
                                </styles:SHTabControl.ContentTemplate>
                            </styles:SHTabControl>
                        </StackPanel>
                    </styles:SHSection>

                    <styles:SHSection Title="Recorded Laps">
                        <StackPanel Margin="12">
                            <TextBlock Margin="0,0,0,8"
                                       FontWeight="Bold"
                                       Text="{Binding SelectedTrackCaption}" />
                            <Button Width="170"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    IsEnabled="{Binding HasSelectedLap}"
                                    Click="ToggleLapValidityButton_Click"
                                    Content="Toggle selected lap valid" />
                            <DataGrid ItemsSource="{Binding SelectedTrackLaps}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      Height="240"
                                      SelectedItem="{Binding SelectedLap, Mode=TwoWay}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lap" Binding="{Binding LapNumber}" Width="55" />
                                    <DataGridTextColumn Header="Time" Binding="{Binding LapTimeSeconds, Converter={StaticResource TimeSpanSecondsFormatter}}" Width="90" />
                                    <DataGridTextColumn Header="S1" Binding="{Binding Sector1Seconds, Converter={StaticResource TimeSpanSecondsFormatter}}" Width="80" />
                                    <DataGridTextColumn Header="S2" Binding="{Binding Sector2Seconds, Converter={StaticResource TimeSpanSecondsFormatter}}" Width="80" />
                                    <DataGridTextColumn Header="S3" Binding="{Binding Sector3Seconds, Converter={StaticResource TimeSpanSecondsFormatter}}" Width="80" />
                                    <DataGridCheckBoxColumn Header="Valid" Binding="{Binding IsValid}" Width="60" />
                                    <DataGridTextColumn Header="Recorded UTC" Binding="{Binding TimestampUtc, StringFormat={}{0:u}}" Width="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </styles:SHSection>
                </StackPanel>
            </styles:SHTabItem>
        </styles:SHTabControl>
    </ScrollViewer>
</UserControl>
